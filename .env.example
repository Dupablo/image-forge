# Image Forge - API Keys
# Copy this file to .env.local and fill in your keys

# OpenAI API Key (required for primary provider - gpt-image-1)
OPENAI_API_KEY=sk-...

# Replicate API Token (optional - for FLUX/SDXL models)
REPLICATE_API_TOKEN=r8_...

# Stability AI API Key (optional - for SD3/inpainting)
STABILITY_API_KEY=sk-...
